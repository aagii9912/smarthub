{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "sin1"
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-messages",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/check-payments",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/check-trial-expiry",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/weekly-token-report",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/cleanup-stale-pushes",
      "schedule": "0 2 * * *"
    }
  ]
}